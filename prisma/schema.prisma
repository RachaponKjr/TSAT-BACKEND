// CMS 

model CarModel {
  id         String   @id @default(uuid()) @db.Uuid
  name       String   @unique
  image      String
  showActive Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @default(now()) @db.Timestamptz

  carSubModels    CarSubModel[]
  CustomerWork    CustomerWork[]
  CustomerReview  CustomerReview[]
  WorkService     WorkService[]
  carServiceLinks CarServiceLink[] // ✅ พหูพจน์ และตรงความหมาย
  CustomerBlog    CustomerBlog[]
}

model CarSubModel {
  id         String   @id @default(uuid()) @db.Uuid
  name       String
  image      String?
  carModelId String   @db.Uuid
  createdAt  DateTime @default(now()) @db.Timestamptz
  updatedAt  DateTime @default(now()) @db.Timestamptz

  carModel       CarModel         @relation(fields: [carModelId], references: [id], onDelete: Cascade)
  carServices    CarService[]
  CustomerReview CustomerReview[]
  WorkService    WorkService[]
  CustomerWork   CustomerWork[]
  CustomerBlog   CustomerBlog[]
}

model CategoryServiceCarModel {
  id        String   @id @default(uuid()) @db.Uuid
  category  String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  carServiceLinks CarServiceLink[] // ✅ Relation ย้อนกลับไปยัง link หลายอัน
}

model CarServiceLink {
  id                        String  @id @default(uuid()) @db.Uuid
  carModelId                String  @db.Uuid
  carServiceId              String  @db.Uuid
  categoryServiceCarModelId String? @db.Uuid

  carModel   CarModel                @relation(fields: [carModelId], references: [id])
  carService CategoryServiceCarModel @relation(fields: [carServiceId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @db.Timestamptz

  @@unique([carModelId, carServiceId]) // ป้องกันไม่ให้ carModel+carService ซ้ำ
}

model CustomerReview {
  id            String       @id @default(uuid()) @db.Uuid
  customerName  String
  review        String
  image         String
  carModelId    String       @db.Uuid
  carModel      CarModel     @relation(fields: [carModelId], references: [id]) // ✅ เพิ่ม relation
  carSubModelId String?      @db.Uuid // 👈 optional
  carSubModel   CarSubModel? @relation(fields: [carSubModelId], references: [id])
  createdAt     DateTime     @default(now()) @db.Timestamptz
  updatedAt     DateTime     @updatedAt @db.Timestamptz
}

model CustomerWork {
  id            String            @id @default(uuid()) @db.Uuid
  title         String
  content       Json // รองรับ Rich Text
  images        String // URL รูปภาพ
  serviceId     String?           @db.Uuid
  subServiceId  String?           @db.Uuid
  carModelId    String?           @db.Uuid
  carSubModelId String?           @db.Uuid
  isShow        Boolean           @default(false)
  // type          BlogType          @default(WorkBlog)
  tags          CustomerWorkTag[] // Many-to-many กับ Tag
  createdAt     DateTime          @default(now()) @db.Timestamptz
  updatedAt     DateTime          @updatedAt @db.Timestamptz

  // Relations
  carSubModel CarSubModel? @relation(fields: [carSubModelId], references: [id], onDelete: SetNull)
  carModel    CarModel?    @relation(fields: [carModelId], references: [id], onDelete: SetNull)
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  subService  SubService?  @relation(fields: [subServiceId], references: [id], onDelete: SetNull)

  // @@index([type])
  @@index([isShow])
  @@index([createdAt])
}

model CustomerBlog {
  id            String   @id @default(uuid()) @db.Uuid
  isShow        Boolean  @default(false)
  title         String
  content       String
  serviceId     String?  @db.Uuid
  subServiceId  String?  @db.Uuid
  carModelId    String?  @db.Uuid
  carSubModelId String?  @db.Uuid
  images        Json?    @default("[]")
  create_at     DateTime @default(now())

  // Relations
  carSubModel CarSubModel? @relation(fields: [carSubModelId], references: [id], onDelete: SetNull)
  carModel    CarModel?    @relation(fields: [carModelId], references: [id], onDelete: SetNull)
  service     Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  subService  SubService?  @relation(fields: [subServiceId], references: [id], onDelete: SetNull)
  tags        BlogsTags[]

  @@index([isShow])
  @@index([create_at])
  @@map("news")
}

model BlogsTags {
  id             Int      @id @default(autoincrement())
  customerblogId String   @db.Uuid
  tagId          String   @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @default(now()) @db.Timestamptz

  customerblog CustomerBlog @relation(fields: [customerblogId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id])
}

model WorkService {
  id            String   @id @default(uuid()) @db.Uuid
  image         String
  carModelId    String   @db.Uuid
  carSubModelId String   @db.Uuid
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  carModel    CarModel    @relation(fields: [carModelId], references: [id])
  carSubModel CarSubModel @relation(fields: [carSubModelId], references: [id])
}

model CustomerWorkTag {
  customerWorkId String   @db.Uuid
  tagId          String   @db.Uuid
  createdAt      DateTime @default(now()) @db.Timestamptz
  updatedAt      DateTime @default(now()) @db.Timestamptz

  customerWork   CustomerWork @relation(fields: [customerWorkId], references: [id], onDelete: Cascade)
  tag            Tag          @relation(fields: [tagId], references: [id])
  customerBlogId String?      @db.Uuid

  @@id([customerWorkId, tagId]) // composite key
}

model CategoryService {
  id        String     @id @default(uuid()) @db.Uuid
  title     String     @unique
  createdAt DateTime   @default(now()) @db.Timestamptz
  updatedAt DateTime   @default(now()) @db.Timestamptz
  Category  Category[]
}

model Service {
  id            String         @id @default(uuid()) @db.Uuid
  title         String?
  explain       String?
  icon          String? //Base64
  serviceName   String?
  serviceDetail String?
  images        String[]
  bgIcon        String? //Base64
  createdAt     DateTime       @default(now()) @db.Timestamptz
  updatedAt     DateTime       @default(now()) @db.Timestamptz
  subService    SubService[]
  // carServices   CarService[] // เพิ่มการเชื่อมโยงไปยัง CarService
  // categoryId    String          @db.Uuid
  // category      CategoryService @relation(fields: [categoryId], references: [id])
  CustomerWork  CustomerWork[]
  CustomerBlog  CustomerBlog[]
}

model SubService {
  id               String         @id @default(uuid()) @db.Uuid
  serviceId        String         @db.Uuid
  subServiceName   String?
  subServiceDetail String?
  Service          Service        @relation(fields: [serviceId], references: [id])
  CustomerWork     CustomerWork[]
  CustomerBlog     CustomerBlog[]
}

model CarService {
  id            String      @id @default(uuid()) @db.Uuid
  carSubModelId String      @db.Uuid
  serviceId     String      @db.Uuid
  createdAt     DateTime    @default(now()) @db.Timestamptz
  updatedAt     DateTime    @default(now()) @db.Timestamptz
  carSubModel   CarSubModel @relation(fields: [carSubModelId], references: [id])
  // service       Service     @relation(fields: [serviceId], references: [id])
}

model Blog {
  id            String    @id @default(uuid()) @db.Uuid
  title         String
  content       Json
  facebookLink  String?   @db.VarChar(255)
  lineLink      String?   @db.VarChar(255)
  instagramLink String?   @db.VarChar(255)
  createdAt     DateTime  @default(now()) @db.Timestamptz
  updatedAt     DateTime  @default(now()) @db.Timestamptz
  blogTags      BlogTag[] // เพิ่มการเชื่อมโยงไปยัง BlogTag
}

model Tag {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @unique
  createdAt       DateTime          @default(now()) @db.Timestamptz
  updatedAt       DateTime          @default(now()) @db.Timestamptz
  blogTags        BlogTag[] // เพิ่มการเชื่อมโยงไปยัง BlogTag
  CustomerWorkTag CustomerWorkTag[]
  BlogsTags       BlogsTags[]
}

model BlogTag {
  blogId    String   @db.Uuid
  tagId     String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @default(now()) @db.Timestamptz
  blog      Blog     @relation(fields: [blogId], references: [id])
  tag       Tag      @relation(fields: [tagId], references: [id])

  @@id([blogId, tagId]) // ใช้ composite key (blogId, tagId)
}

model Category {
  id                String           @id @default(uuid()) @db.Uuid
  name              String           @unique
  image             String
  products          Product[]
  categoryServiceId String?          @db.Uuid
  categoryService   CategoryService? @relation(fields: [categoryServiceId], references: [id])
  createdAt         DateTime         @default(now()) @db.Timestamptz
  updatedAt         DateTime         @updatedAt @db.Timestamptz
}

model Product {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  detail       String
  imageProduct String
  categoryId   String?   @db.Uuid
  category     Category? @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

enum Role {
  USER
  ADMIN
  OWNER
  MECHANIC
}

// enum BlogType {
//   WorkBlog
//   ReviewBlog
// }

model User {
  id        String   @id @default(uuid()) @db.Uuid
  username  String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz
}

// ============================
// TEMPLATE LAYER (ตายตัว)
// ============================

model InspectionTemplate {
  id         String                       @id @default(cuid())
  name       String // เช่น "แบบตรวจสภาพรถใช้แล้ว v1"
  isActive   Boolean                      @default(true)
  categories InspectionCategoryTemplate[]
  reports    InspectionReport[]
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt
}

// กลุ่มใหญ่ เช่น "ขับขี่ได้ปกติทั้งกลางวันและกลางคืน"
model InspectionCategoryTemplate {
  id         String                     @id @default(cuid())
  templateId String
  template   InspectionTemplate         @relation(fields: [templateId], references: [id])
  name       String
  order      Int                        @default(0)
  items      InspectionItemTemplate[]
  results    InspectionCategoryResult[]

  @@index([templateId])
}

// รายการย่อยในกลุ่ม เช่น "ระบบสตาร์ทเครื่องยนต์"
model InspectionItemTemplate {
  id          String                       @id @default(cuid())
  categoryId  String
  category    InspectionCategoryTemplate   @relation(fields: [categoryId], references: [id])
  name        String
  description String? // เช่น "สตาร์ทง่าย ติดทันที ไม่มีเสียงผิดปกติ"
  order       Int                          @default(0)
  criteria    InspectionCriteriaTemplate[]
  results     InspectionItemResult[]

  @@index([categoryId])
}

// หัวข้อคะแนนย่อยของแต่ละรายการ เช่น "คะแนนประเมินสภาพ", "คะแนนระยะทาง(เลขไมล์)", "คะแนนอายุการใช้งาน"
model InspectionCriteriaTemplate {
  id      String                     @id @default(cuid())
  itemId  String
  item    InspectionItemTemplate     @relation(fields: [itemId], references: [id])
  label   String // "คะแนนประเมินสภาพ"
  order   Int                        @default(0)
  options InspectionCriteriaOption[] // rubric ตายตัว
  results InspectionCriteriaResult[]

  @@index([itemId])
}

// ตัวเลือกคะแนนของแต่ละหัวข้อ (หลักเกณฑ์การให้คะแนน) เช่น
// 3 = "สภาพใช้งานได้ปกติ", 2 = "ถึงกำหนดเปลี่ยนแต่ยังใช้งานได้", 1 = "สภาพชำรุดต้องเปลี่ยน"
model InspectionCriteriaOption {
  id                        String                     @id @default(cuid())
  criteriaId                String
  criteria                  InspectionCriteriaTemplate @relation(fields: [criteriaId], references: [id])
  score                     Int // 3, 2, 1 ...
  description               String // คำอธิบาย default ของคะแนนนี้
  order                     Int                        @default(0)
  inspectionCriteriaResults InspectionCriteriaResult[]

  @@index([criteriaId])
}

// ============================
// REPORT LAYER (ต่อใบตรวจ)
// ============================
model InspectionReport {
  id         String             @id @default(cuid())
  templateId String
  template   InspectionTemplate @relation(fields: [templateId], references: [id])

  imageCar     String?
  customerName String // ลูกค้า
  carModel     String // รุ่นรถ
  modelYear    String // ปี
  vin          String // รหัสตัวถัง (VIN)
  odometer     Int // เลขไมล์
  licensePlate String // ทะเบียน

  inspectorName String?
  inspectedAt   DateTime?
  approverName  String?
  approvedAt    DateTime?

  overallGrade String? // A, B, C...
  totalScore   Int?
  maxScore     Int?

  categoryResults InspectionCategoryResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([templateId])
  @@index([customerName])
}

// ผลของแต่ละกลุ่มในใบตรวจนี้ (คะแนนรวมของกลุ่ม)
model InspectionCategoryResult {
  id         String                     @id @default(cuid())
  reportId   String
  report     InspectionReport           @relation(fields: [reportId], references: [id], onDelete: Cascade)
  categoryId String
  category   InspectionCategoryTemplate @relation(fields: [categoryId], references: [id])

  score    Int @default(0)
  maxScore Int @default(0)

  itemResults InspectionItemResult[]

  @@unique([reportId, categoryId])
  @@index([reportId])
}

// ผลของแต่ละรายการ (เช่น ระบบสตาร์ทเครื่องยนต์) ในใบตรวจนี้
model InspectionItemResult {
  id               String                   @id @default(cuid())
  categoryResultId String
  categoryResult   InspectionCategoryResult @relation(fields: [categoryResultId], references: [id], onDelete: Cascade)
  itemId           String
  item             InspectionItemTemplate   @relation(fields: [itemId], references: [id])

  imageUrl    String?
  score       Int     @default(0)
  maxScore    Int     @default(0)
  description String? @default("")
  recommend   String? @default("")

  criteriaResults InspectionCriteriaResult[]

  @@unique([categoryResultId, itemId])
  @@index([categoryResultId])
}

// ผลของหัวข้อคะแนนย่อย — จุดที่ "เปลี่ยนได้แค่คะแนนกับคำอธิบาย"
model InspectionCriteriaResult {
  id           String                     @id @default(cuid())
  itemResultId String
  itemResult   InspectionItemResult       @relation(fields: [itemResultId], references: [id], onDelete: Cascade)
  criteriaId   String
  criteria     InspectionCriteriaTemplate @relation(fields: [criteriaId], references: [id])

  selectedOptionId String? // ref ตัวเลือก rubric ที่เลือก (ถ้าเลือกจาก dropdown)
  selectedOption   InspectionCriteriaOption? @relation(fields: [selectedOptionId], references: [id])

  score       Int // ค่าจริงที่ใช้ (แก้ไขได้ แม้จะมาจาก option เดิม)
  description String // คำอธิบายจริงที่ใช้ (แก้ไขได้)

  @@unique([itemResultId, criteriaId])
  @@index([itemResultId])
}
